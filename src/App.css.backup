.site-shell {
  position: relative;
  overflow-x: clip;
}

.site-shell::before,
.site-shell::after {
  content: '';
  position: fixed;
  border-radius: 999px;
  filter: blur(110px);
  pointer-events: none;
  z-index: -2;
}

.site-shell::before {
  top: -10rem;
  right: -8rem;
  width: 28rem;
  height: 28rem;
  background: rgba(208, 169, 103, 0.22);
}

.site-shell::after {
  left: -8rem;
  bottom: 4rem;
  width: 24rem;
  height: 24rem;
  background: rgba(34, 88, 73, 0.16);
}

.page-shell {
  width: min(1400px, calc(100% - 2.25rem));
  margin: 0 auto;
  margin-top: clamp(4.5rem, 6vw, 6rem);
}

.topbar {
  position: fixed;
  top: 1rem;
  left: 50%;
  transform: translateX(-50%);
  z-index: 30;
  width: min(1460px, calc(100% - 2.25rem));
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.5rem;
  padding: 0.9rem 1.2rem;
  border: 1px solid rgba(255, 255, 255, 0.15);
  border-radius: 1.4rem;
  background: rgba(14, 23, 20, 0.58);
  box-shadow: 0 24px 60px rgba(6, 12, 11, 0.2);
  backdrop-filter: blur(18px);
}

.brand,
.footer__brand {
  display: flex;
  align-items: center;
  gap: 0.9rem;
}

.brand--button,
.nav button,
.service-card__content button,
.footer__links button {
  border: 0;
  background: transparent;
  cursor: pointer;
  font: inherit;
}

.brand--button {
  padding: 0;
  color: inherit;
}

.brand__copy {
  display: grid;
  gap: 0.15rem;
  text-align: left;
}

.brand__logo,
.footer__logo {
  width: 3.2rem;
  height: 3.2rem;
  object-fit: contain;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.82);
  padding: 0.35rem;
}

.brand__name {
  margin: 0;
  color: #f7f2ea;
  font-size: 0.98rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.brand__tag {
  margin: 0;
  color: rgba(247, 242, 234, 0.74);
  font-size: 0.9rem;
}

.nav,
.trust-strip__items,
.info-tiles,
.intro-split__grid,
.band-section__grid,
.services-grid,
.process-showcase__grid,
.process-steps,
.mosaic-grid,
.founder-teaser__grid,
.credentials-grid,
.narrative-grid,
.story-layout,
.comparison-grid,
.blog-grid,
.contact-grid,
.timeline-layout,
.hero__grid,
.metrics {
  display: grid;
  gap: 1rem;
}

.nav {
  grid-auto-flow: column;
  align-items: center;
}

.nav button,
.footer__links button {
  color: rgba(247, 242, 234, 0.84);
  padding: 0;
}

.nav button.is-active {
  color: #f2cf99;
}

.hero,
.page-hero {
  position: relative;
  padding-top: clamp(5.5rem, 8vw, 7.5rem);
}

.hero {
  min-height: clamp(32rem, 75vh, 48rem);
  display: flex;
  align-items: flex-end;
  padding-bottom: clamp(1.25rem, 2.5vw, 2rem);
}

.hero__media,
.hero__overlay,
.page-hero__media {
  position: absolute;
  inset: 0;
}

.hero__media,
.page-hero__media {
  border-radius: 2rem;
  overflow: hidden;
  background-size: cover;
  background-position: center;
  box-shadow: 0 30px 90px rgba(8, 15, 14, 0.16);
}

.hero__overlay {
  background:
    linear-gradient(180deg, rgba(7, 11, 12, 0.22) 0%, rgba(7, 11, 12, 0.54) 48%, rgba(7, 11, 12, 0.88) 100%),
    linear-gradient(90deg, rgba(8, 14, 13, 0.74) 0%, rgba(8, 14, 13, 0.3) 45%, rgba(8, 14, 13, 0.14) 100%);
}

.hero__content,
.page-hero__content {
  position: relative;
  z-index: 2;
}

.hero__content {
  width: 100%;
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 clamp(1.25rem, 3vw, 3rem) clamp(0.75rem, 1.5vw, 1.2rem);
}

.hero__grid {
  grid-template-columns: minmax(0, 1fr) minmax(320px, 0.55fr);
  align-items: center;
  gap: clamp(1.5rem, 3vw, 3rem);
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  color: var(--color-accent);
  font-size: 0.78rem;
  font-weight: 800;
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

.eyebrow--light {
  color: rgba(241, 227, 206, 0.92);
}

.hero__copy h1,
.page-hero__content h1,
.section-heading h2,
.glass-card h2,
.band-card p,
.image-panel h3,
.final-cta__panel h2,
.hero__spotlight-title {
  margin: 0;
  font-family: var(--font-display);
  letter-spacing: -0.045em;
}

.hero__copy {
  max-width: 42rem;
  padding-left: 2rem;
}

.hero__copy h1 {
  max-width: 30ch;
  margin-top: 1rem;
  color: #f8f3eb;
  font-size: clamp(2.9rem, 5vw, 4.7rem);
  line-height: 0.92;
}

.hero__lead,
.hero__spotlight p,
.metric-card span,
.section-heading p,
.glass-card p,
.service-card p,
.process-step p,
.mosaic-card p,
.timeline-card p,
.blog-card p,
.contact-card p,
.page-hero__content p,
.footer__copyright,
.footer__socials span {
  color: var(--color-muted);
}

.hero__lead {
  max-width: 26rem;
  margin-top: 1rem;
  color: rgba(248, 243, 235, 0.78);
  font-size: 0.98rem;
}

.hero__pills {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-top: 1.5rem;
}

.hero__pills span,
.pill-tag {
  display: inline-flex;
  padding: 0.78rem 1rem;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(248, 243, 235, 0.88);
  font-size: 0.92rem;
  font-weight: 700;
  backdrop-filter: blur(12px);
}

.hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.9rem;
  margin-top: 1.5rem;
}

.button,
.service-card__content button,
.blog-card button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 3.35rem;
  padding: 0 1.4rem;
  border-radius: 999px;
  border: 1px solid transparent;
  font-weight: 800;
  text-decoration: none;
  transition:
    transform 180ms ease,
    background 180ms ease,
    border-color 180ms ease;
}

.button:hover,
.button:focus-visible,
.service-card__content button:hover,
.blog-card button:hover {
  transform: translateY(-2px);
}

.button--primary,
.service-card__content button,
.blog-card button {
  background: linear-gradient(135deg, #e4ba7a 0%, #d1a160 100%);
  color: #1b1307;
  box-shadow: 0 18px 40px rgba(209, 161, 96, 0.25);
}

.button--secondary {
  border-color: rgba(255, 255, 255, 0.18);
  background: rgba(255, 255, 255, 0.08);
  color: #f8f3eb;
  backdrop-filter: blur(10px);
}

.hero__spotlight {
  max-width: 24rem;
  justify-self: end;
  padding: 1.6rem;
  border: 1px solid rgba(255, 255, 255, 0.14);
  border-radius: 2rem;
  background:
    linear-gradient(180deg, rgba(255, 252, 247, 0.95), rgba(247, 239, 229, 0.9)),
    rgba(255, 251, 245, 0.9);
  box-shadow: 0 30px 80px rgba(4, 9, 8, 0.26);
}

.hero__spotlight-label,
.service-card__kicker,
.blog-card span {
  margin: 0 0 1rem;
  color: var(--color-accent-strong);
  font-size: 0.84rem;
  font-weight: 800;
  letter-spacing: 0.15em;
  text-transform: uppercase;
}

.hero__spotlight-title {
  color: #203730;
  font-size: clamp(1.6rem, 2.5vw, 2.2rem);
  line-height: 0.98;
}

.hero__spotlight p {
  margin: 0;
  font-size: 0.98rem;
  color: #203730;
}

.hero__spotlight-line {
  width: 100%;
  height: 1px;
  margin: 1.4rem 0;
  background: rgba(32, 55, 48, 0.14);
}

.hero__spotlight-note {
  color: #4f635d !important;
}

.metrics {
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 1rem;
}

.metric-card,
.glass-card,
.process-step,
.mosaic-card,
.timeline-card,
.blog-card,
.contact-card,
.credential-card,
.footer {
  border: 1px solid rgba(20, 35, 31, 0.08);
  box-shadow: var(--shadow-soft);
}

.metric-card {
  padding: 1rem 1.1rem;
  border-radius: 1.4rem;
  background: rgba(255, 255, 255, 0.07);
  backdrop-filter: blur(12px);
}

.metric-card strong {
  display: block;
  color: #f8f3eb;
  font-size: 1.5rem;
}

.section {
  padding: 6rem 0;
}

.trust-strip__items {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.trust-strip__items span,
.footer__links button {
  display: inline-flex;
  justify-content: center;
  padding: 1rem 1.2rem;
  border: 1px solid rgba(20, 35, 31, 0.08);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.6);
  color: #294038;
  font-weight: 700;
}

.section-heading {
  max-width: 46rem;
}

.section-heading--wide {
  max-width: 52rem;
}

.info-tiles {
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 2rem;
}

.info-tile {
  padding: 1.6rem;
  border: 1px solid rgba(20, 35, 31, 0.08);
  border-radius: 1.7rem;
  background: rgba(255, 252, 247, 0.82);
  box-shadow: var(--shadow-soft);
}

.info-tile strong {
  display: block;
  color: #203730;
  font-size: 1.15rem;
}

.info-tile p {
  margin-top: 0.85rem;
  color: var(--color-muted);
}

.section-heading h2,
.glass-card h2,
.final-cta__panel h2,
.page-hero__content h1 {
  color: var(--color-text);
  font-size: clamp(2.4rem, 4.8vw, 4.7rem);
  line-height: 0.95;
}

.section-heading p,
.glass-card p,
.page-hero__content p,
.final-cta__panel p {
  margin-top: 1rem;
  font-size: 1.02rem;
}

.intro-split__grid,
.founder-teaser__grid,
.story-layout {
  grid-template-columns: 0.9fr 1.1fr;
  margin-top: 2rem;
  align-items: stretch;
}

.glass-card,
.image-panel,
.band-card,
.final-cta__panel,
.page-hero__media {
  border-radius: 2rem;
}

.glass-card,
.contact-card,
.blog-card {
  padding: 2rem;
  background: rgba(255, 252, 247, 0.82);
}

.copy-card {
  display: grid;
  align-content: center;
  gap: 1rem;
}

.story-layout__copy {
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 100%;
}

.story-layout__copy--card {
  padding: 2rem;
  border: 1px solid rgba(20, 35, 31, 0.08);
  border-radius: 2rem;
  background: rgba(255, 252, 247, 0.82);
  box-shadow: var(--shadow-soft);
}

.story-layout__copy h2 {
  margin: 0;
  color: var(--color-text);
  font-family: var(--font-display);
  font-size: clamp(2.1rem, 3.8vw, 3.6rem);
  line-height: 0.96;
  letter-spacing: -0.04em;
}

.story-layout__copy p {
  margin-top: 1rem;
  color: var(--color-muted);
}

.image-panel {
  min-height: 24rem;
  background-size: cover;
  background-position: center;
  box-shadow: 0 24px 70px rgba(18, 28, 24, 0.14);
}

.image-panel--tall {
  min-height: 28rem;
  display: flex;
  align-items: flex-end;
  padding: 2rem;
}

.image-panel--portrait {
  min-height: 28rem;
}

.image-panel h3 {
  max-width: 10ch;
  color: #f8f3eb;
  font-size: clamp(2rem, 4vw, 3.7rem);
  line-height: 0.96;
}

.band-section__grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.band-card {
  padding: 2rem;
}

.band-card--dark {
  background:
    linear-gradient(135deg, rgba(17, 52, 43, 0.98), rgba(30, 79, 66, 0.92)),
    var(--color-text);
}

.band-card--dark p {
  color: rgba(248, 243, 235, 0.84);
  font-size: 1.3rem;
}

.band-card--accent {
  background: rgba(255, 249, 241, 0.9);
}

.band-card--accent p {
  color: #203730;
  font-size: 1.3rem;
}

.services-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 2rem;
}

.services-grid--full {
  margin-top: 0;
}

.service-card {
  position: relative;
  min-height: 28rem;
  display: flex;
  align-items: flex-end;
  border-radius: 2rem;
  overflow: hidden;
  background-size: cover;
  background-position: center;
  box-shadow: 0 24px 70px rgba(18, 28, 24, 0.14);
}

.service-card--large {
  min-height: 30rem;
}

.service-card__content {
  padding: 2rem;
}

.service-card h3 {
  margin: 0;
  color: #f8f3eb;
  font-size: 1.7rem;
}

.service-card p {
  margin-top: 0.9rem;
  color: rgba(248, 243, 235, 0.8);
}

.process-showcase__grid {
  grid-template-columns: 0.7fr 1.3fr;
  align-items: start;
}

.process-copy h2 {
  margin: 0.6rem 0 0;
  font-family: var(--font-display);
  font-size: clamp(2.4rem, 4.4vw, 4.2rem);
  line-height: 0.95;
}

.process-steps {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.process-step {
  padding: 1.8rem;
  border-radius: 1.7rem;
  background: rgba(255, 252, 247, 0.82);
}

.process-step strong,
.timeline-card strong {
  color: var(--color-accent-strong);
  font-size: 1.5rem;
}

.process-step h3,
.mosaic-card h3,
.blog-card h3,
.contact-card h3 {
  margin: 0.8rem 0 0;
  color: #203730;
  font-size: 1.25rem;
}

.mosaic-grid {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.mosaic-card {
  min-height: 15rem;
  padding: 1.6rem;
  border-radius: 1.7rem;
  background: rgba(255, 252, 247, 0.82);
}

.mosaic-card--image {
  background-size: cover;
  background-position: center;
}

.mosaic-card--accent {
  background:
    linear-gradient(135deg, rgba(214, 190, 154, 0.54), rgba(255, 255, 255, 0.72)),
    rgba(255, 252, 247, 0.82);
}

.credentials-grid {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.credential-card {
  display: grid;
  align-content: space-between;
  min-height: 12rem;
  padding: 1.5rem;
  border-radius: 1.6rem;
  background: rgba(255, 252, 247, 0.82);
}

.credential-card__mark {
  width: 2.8rem;
  height: 2.8rem;
  border-radius: 999px;
  background:
    radial-gradient(circle at 30% 30%, #f6dfbb, #c58b4f 70%, #8a5a2a 100%);
  box-shadow: inset 0 0 0 0.3rem rgba(255, 255, 255, 0.38);
}

.quote-block blockquote {
  margin: 0;
  padding: 3rem;
  border-radius: 2rem;
  background:
    linear-gradient(125deg, rgba(11, 25, 22, 0.98), rgba(22, 57, 48, 0.95)),
    var(--color-text);
  color: #f8f3eb;
  font-family: var(--font-display);
  font-size: clamp(2rem, 4vw, 3.8rem);
  line-height: 1;
  box-shadow: 0 24px 70px rgba(18, 28, 24, 0.14);
}

.final-cta__panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.5rem;
  padding: 2rem;
  background:
    linear-gradient(125deg, rgba(11, 25, 22, 0.98), rgba(22, 57, 48, 0.95)),
    var(--color-text);
}

.final-cta__panel h2,
.final-cta__panel p {
  color: #f8f3eb;
}

.page-hero {
  min-height: 31rem;
  display: flex;
  align-items: flex-end;
  padding-bottom: 2rem;
}

.page-hero__content {
  position: relative;
  z-index: 2;
  max-width: 38rem;
  padding: 0 2.25rem 1rem;
}

.page-hero__content h1 {
  margin-top: 1rem;
  color: #f8f3eb;
  font-size: clamp(2.9rem, 5vw, 4.6rem);
}

.page-hero__content p {
  max-width: 31rem;
  color: rgba(248, 243, 235, 0.82);
}

.detail-points {
  display: grid;
  gap: 0.85rem;
  margin-top: 1.25rem;
}

.detail-point {
  padding: 0.95rem 1rem;
  border: 1px solid rgba(20, 35, 31, 0.08);
  border-radius: 1rem;
  background: rgba(255, 255, 255, 0.72);
  color: #294038;
  font-weight: 600;
}

.narrative-grid,
.comparison-grid,
.contact-grid,
.blog-grid,
.timeline-layout {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.founder-page-grid {
  display: grid;
  grid-template-columns: 1fr 0.9fr;
  gap: 1rem;
}

.timeline-card {
  padding: 1.6rem;
  border-radius: 1.6rem;
  background: rgba(255, 252, 247, 0.82);
}

.contact-card a {
  color: #203730;
  font-weight: 700;
  text-decoration: none;
}

.footer {
  margin: 0 auto 2rem;
  padding: 2rem;
  border-radius: 2rem;
  background: rgba(255, 252, 247, 0.84);
}

.footer__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.5rem;
}

.footer__brand-button {
  color: inherit;
}

.footer__brand-button .brand__name {
  color: var(--color-text);
}

.footer__brand-button .brand__tag {
  color: var(--color-muted);
}

.footer__links {
  display: flex;
  flex-wrap: wrap;
  gap: 0.7rem;
}

.footer__links button {
  justify-content: center;
  color: #304740;
}

.footer__socials {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1rem;
  margin-top: 1.6rem;
}

.footer__socials--page {
  margin-top: 0;
}

.footer__socials a {
  color: inherit;
  text-decoration: none;
}

.social-card {
  display: flex;
  align-items: center;
  gap: 1rem;
  position: relative;
  overflow: hidden;
  padding: 1.2rem;
  border: 1px solid rgba(20, 35, 31, 0.08);
  border-radius: 1.4rem;
  background: rgba(255, 255, 255, 0.68);
  transition:
    transform 180ms ease,
    box-shadow 180ms ease,
    border-color 180ms ease;
}

.social-card:hover,
.social-card:focus-visible {
  transform: translateY(-3px);
  box-shadow: 0 18px 40px rgba(19, 31, 28, 0.12);
}

.social-card::after {
  content: '';
  position: absolute;
  inset: auto 0 0 0;
  height: 3px;
  opacity: 0.95;
}

.social-card__icon {
  flex: 0 0 auto;
  width: 3rem;
  height: 3rem;
  display: grid;
  place-items: center;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: inset 0 0 0 1px rgba(20, 35, 31, 0.06);
}

.social-card__icon svg {
  width: 1.65rem;
  height: 1.65rem;
  display: block;
}

.social-card__copy {
  display: grid;
  gap: 0.2rem;
}

.social-card__copy strong {
  color: #203730;
}

.social-card--instagram {
  border-color: rgba(214, 41, 118, 0.16);
  background:
    linear-gradient(135deg, rgba(254, 218, 117, 0.15), rgba(214, 41, 118, 0.06)),
    rgba(255, 255, 255, 0.72);
}

.social-card--instagram::after {
  background: linear-gradient(90deg, #feda75, #fa7e1e, #d62976, #962fbf, #4f5bd5);
}

.social-card--linkedin {
  border-color: rgba(10, 102, 194, 0.16);
  background:
    linear-gradient(135deg, rgba(10, 102, 194, 0.12), rgba(10, 102, 194, 0.03)),
    rgba(255, 255, 255, 0.72);
}

.social-card--linkedin::after {
  background: #0a66c2;
}

.social-card--facebook {
  border-color: rgba(24, 119, 242, 0.16);
  background:
    linear-gradient(135deg, rgba(24, 119, 242, 0.12), rgba(24, 119, 242, 0.03)),
    rgba(255, 255, 255, 0.72);
}

.social-card--facebook::after {
  background: #1877f2;
}

.footer__copyright {
  margin: 1.6rem 0 0;
  font-size: 0.92rem;
}

@media (max-width: 1180px) {
  .hero__grid,
  .intro-split__grid,
  .founder-teaser__grid,
  .story-layout,
  .process-showcase__grid,
  .founder-page-grid,
  .band-section__grid,
  .services-grid,
  .credentials-grid,
  .info-tiles,
  .comparison-grid,
  .contact-grid,
  .blog-grid,
  .narrative-grid,
  .timeline-layout {
    grid-template-columns: 1fr;
  }

  .hero__spotlight {
    max-width: none;
    justify-self: stretch;
  }

  .metrics,
  .process-steps,
  .mosaic-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .hero__copy h1 {
    max-width: 30ch;
  }

  .hero__copy {
    padding-left: 0;
  }
}

@media (max-width: 820px) {
  .topbar,
  .footer__top {
    flex-direction: column;
    align-items: flex-start;
  }

  .nav {
    grid-auto-flow: row;
    justify-items: start;
  }

  .hero__content,
  .page-hero__content {
    padding-left: 1.25rem;
    padding-right: 1.25rem;
  }

  .metrics,
  .trust-strip__items,
  .process-steps,
  .mosaic-grid,
  .footer__socials {
    grid-template-columns: 1fr;
  }

  .final-cta__panel {
    flex-direction: column;
    align-items: flex-start;
  }
}

@media (max-width: 640px) {
  .page-shell {
    width: min(100% - 1.25rem, 1400px);
  }

  .topbar {
    width: min(100% - 1rem, 1460px);
    top: 0.5rem;
    padding: 0.85rem 1rem;
  }

  .hero__copy h1,
  .page-hero__content h1 {
    font-size: clamp(2.6rem, 13vw, 3.8rem);
  }

  .hero__media,
  .page-hero__media,
  .quote-block blockquote,
  .glass-card,
  .image-panel,
  .service-card,
  .footer {
    border-radius: 1.5rem;
  }

  .section {
    padding: 4.5rem 0;
  }

  .hero,
  .page-hero {
    padding-top: 8.75rem;
  }
}
